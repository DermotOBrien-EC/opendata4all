{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opendata4all.org/schemas/package-manifest.schema.json",
  "title": "OD4A Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "version",
    "release_tier",
    "created_at",
    "publisher",
    "license",
    "source_adapters",
    "files",
    "consent_receipts",
    "redaction_reports",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "release_tier": {
      "enum": [
        "raw_vault",
        "local_review",
        "controlled_research",
        "public_release",
        "reproducibility_snapshot"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "contact"],
      "properties": {
        "name": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "access_terms": {
          "type": "string"
        }
      }
    },
    "source_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/adapter_metadata"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "media_type", "sha256", "bytes"],
        "properties": {
          "path": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "row_count": {
            "type": "integer",
            "minimum": 0
          },
          "schema_id": {
            "type": "string"
          },
          "contains_raw_data": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "consent_receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redaction_reports": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {
          "enum": ["passed", "failed", "waived"]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "supersedes": {
      "type": "string"
    },
    "takedown_index": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "release_tier": {
            "enum": [
              "controlled_research",
              "public_release",
              "reproducibility_snapshot"
            ]
          }
        },
        "required": ["release_tier"]
      },
      "then": {
        "properties": {
          "consent_receipts": {
            "minItems": 1
          },
          "redaction_reports": {
            "minItems": 1
          },
          "files": {
            "items": {
              "properties": {
                "contains_raw_data": {
                  "not": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "adapter_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "capture_method": {
          "enum": [
            "native_api",
            "documented_hook",
            "structured_cli",
            "user_export",
            "manual_import",
            "mcp_proxy",
            "other_documented"
          ]
        }
      }
    }
  }
}
